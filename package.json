{
  "name": "visual-testing",
  "version": "1.0.0",
  "description": "Cypress project for Visual Testing with Percy",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:visual": "npx cypress run --spec 'cypress/e2e/visual-test.cy.js'",
