{
  "name": "visual-testing",
  "version": "1.0.0",
  "description": "Cypress project for Visual Testing",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:visual": "npx happo-e2e -- npx cypress run --spec 'cypress/e2e/visual-test.cy.js'",
    "test:perf": "cypress run --spec 'cypress/e2e/lighthouse.cy.js' --browser --headed"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fugazi/visual-testing.git"
  },
  "keywords": [
    "cypress",
    "visual",
    "testing",
    "qa",
    "automation"
  ],
